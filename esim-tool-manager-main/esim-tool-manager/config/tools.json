{
    "ngspice": {
        "name": "Ngspice",
        "description": "Open source spice simulator for electronic circuit simulation",
        "homepage": "http://ngspice.sourceforge.net/",
        "versions": {
            "latest": "43",
            "stable": "42",
            "available": ["43", "42", "41", "40", "39"]
        },
        "urls": {
            "windows": "https://sourceforge.net/projects/ngspice/files/ng-spice-rework/{version}/ngspice-{version}_64.zip/download",
            "linux": "https://sourceforge.net/projects/ngspice/files/ng-spice-rework/{version}/ngspice-{version}.tar.gz/download",
            "darwin": "brew install ngspice"
        },
        "dependencies": ["libreadline", "libpthread"],
        "verify_command": "ngspice --version",
        "environment": {
            "SPICE_LIB_DIR": "{INSTALL_PATH}/share/ngspice",
            "SPICE_SCRIPTS": "{INSTALL_PATH}/share/ngspice/scripts"
        }
    },
    "kicad": {
        "name": "KiCad",
        "description": "Electronic Design Automation suite for schematic and PCB design",
        "homepage": "https://www.kicad.org/",
        "versions": {
            "latest": "9.0",
            "stable": "8.0",
            "available": ["9.0", "8.0", "7.0", "6.0"]
        },
        "urls": {
            "windows": "https://github.com/KiCad/kicad-source-mirror/releases/download/{version}/kicad-{version}-x86_64.exe",
            "linux": "sudo add-apt-repository ppa:kicad/kicad-9.0-releases && sudo apt install kicad",
            "darwin": "brew install --cask kicad"
        },
        "dependencies": ["python3", "wxwidgets"],
        "verify_command": "kicad --version"
    }
}